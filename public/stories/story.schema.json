{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "interactive-ppd-story-schema",
  "title": "Interactive Video Story Definition",
  "description": "Schema for defining branching interactive video stories.",
  "type": "object",
  "required": ["meta", "config", "startNodeId", "nodes"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "description", "author", "version", "date"],
      "properties": {
        "title": { "type": "string", "description": "Display title of the story" },
        "description": { "type": "string", "description": "Short description / tagline" },
        "author": { "type": "string", "description": "Author or creator name" },
        "version": { "type": "string", "description": "Version string (SemVer)" },
        "date": { "type": "string", "description": "ISO date of creation or last update" },
        "thumbnail": { "type": "string", "description": "Thumbnail image filename" },
        "estimatedMinutes": { "type": "number", "description": "Estimated duration in minutes" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Content tags" }
      }
    },
    "config": {
      "type": "object",
      "required": ["videoBasePath"],
      "properties": {
        "videoBasePath": { "type": "string", "description": "Path to video files relative to public root" },
        "preloadNext": { "type": "boolean", "default": true },
        "defaultVolume": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "allowRevisit": { "type": "boolean", "default": false },
        "choiceLeadTime": { "type": "number", "minimum": 0, "default": 0 }
      }
    },
    "startNodeId": {
      "type": "string",
      "description": "ID of the starting node"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "videoFile", "choices"],
        "properties": {
          "id": { "type": "string", "description": "Unique node identifier" },
          "title": { "type": "string", "description": "Human-readable title" },
          "type": {
            "type": "string",
            "enum": ["start", "video", "ending"],
            "description": "Node type"
          },
          "videoFile": { "type": "string", "description": "Video filename (e.g. intro.mp4)" },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "targetNodeId"],
              "properties": {
                "id": { "type": "string", "description": "Unique choice ID within parent node" },
                "label": { "type": "string", "description": "Display text for the choice" },
                "targetNodeId": { "type": "string", "description": "ID of the target node" },
                "showAtTime": { "type": "number", "description": "Timestamp in seconds when choice appears" },
                "condition": { "type": "string", "description": "Flag key required to show this choice" }
              }
            }
          },
          "choiceTiming": {
            "type": "string",
            "enum": ["on_end", "during_video", "on_pause"],
            "default": "on_end"
          },
          "subtitle": { "type": "string", "description": "Text shown during video playback" },
          "theme": { "type": "string", "description": "CSS theme class or background color" },
          "setsFlags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Flags to set when node is visited"
          }
        }
      }
    }
  }
}
